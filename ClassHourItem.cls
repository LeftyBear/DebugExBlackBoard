Private Function CountedTimeTableName(ByVal RecordList As Dictionary, ByVal Grade As Long, ByVal TimeTableName As String) As Long
    Dim RET As Long
    Dim Period As Long
    For Period = 1 To 6
        Dim FindItemNameParts(TimeTableItemNameParts.Grade) As String
