VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "ClassClassHour"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
'@Folder("FormExBB")
Option Explicit
Private ClassHoursList_ As Dictionary
Private TimeTables_ As Dictionary
Public Property Set ClassHoursList(ByVal Target As Dictionary)
    Set ClassHoursList_ = Target
End Property
Public Property Get ClassHoursList() As Dictionary
    Set ClassHoursList = ClassHoursList_
End Property
Public Property Set TimeTables(ByVal Target As Dictionary)
    Set TimeTables_ = Target
End Property
Public Property Get TimeTables() As Dictionary
    Set TimeTables = TimeTables_
End Property
Public Function TotalGrade(ByVal Grade As String) As Long
    Dim RET As Long
    Select Case Grade
        Case "1봏", "2봏", "3봏"
            RET = Sum롻떾(Grade) + Sum뛱럷(Grade) + Sum럺벛됵(Grade)
        Case "4봏"
            RET = Sum롻떾(Grade) + Sum뛱럷(Grade) + Sum럺벛됵(Grade) + Sum긏깋긳
        Case "5봏", "6봏"
            RET = Sum롻떾(Grade) + Sum뛱럷(Grade) + Sum럺벛됵(Grade) + Sum긏깋긳 + Sum댬덒됵
    End Select
    TotalGrade = RET
End Function
Private Function Sum롻떾(ByVal Grade As String) As Long
    Sum롻떾 = Me.ClassHoursList.Item("롻떾" & Grade)
End Function
Private Function Sum뛱럷(ByVal Grade As String) As Long
    Sum뛱럷 = Me.ClassHoursList.Item("뛱럷" & Grade)
End Function
Private Function Sum럺벛됵(ByVal Grade As String) As Long
    Sum럺벛됵 = Me.ClassHoursList.Item("럺벛됵" & Grade)
End Function
Private Function Sum긏깋긳() As Long
    Sum긏깋긳 = Me.ClassHoursList.Item("긏깋긳")
End Function
Private Function Sum댬덒됵() As Long
    Sum댬덒됵 = Me.ClassHoursList.Item("댬덒됵")
End Function
Public Function MismatchedClassHourMessage() As String
    Dim Messages As Collection
    Set Messages = New Collection
    Dim Grades() As Variant
    Grades = Array("1봏", "2봏", "3봏", "4봏", "5봏", "6봏")
    Dim i As Long
    For i = 0 To 5
        Dim MismatchedList As Collection
        Set MismatchedList = New Collection
        Select Case Grades(i)
            Case "1봏", "2봏", "3봏"
                If Mismatched롻떾(Grades(i)) Then MismatchedList.Add "롻떾"
                If Mismatched뛱럷(Grades(i)) Then MismatchedList.Add "뛱럷"
                If Mismatched럺벛됵(Grades(i)) Then MismatchedList.Add "럺벛됵"
            Case "4봏"
                If Mismatched롻떾(Grades(i)) Then MismatchedList.Add "롻떾"
                If Mismatched뛱럷(Grades(i)) Then MismatchedList.Add "뛱럷"
                If Mismatched럺벛됵(Grades(i)) Then MismatchedList.Add "럺벛됵"
                If Mismatched긏깋긳(Grades(i)) Then MismatchedList.Add "긏깋긳"
            Case "5봏", "6봏"
                If Mismatched롻떾(Grades(i)) Then MismatchedList.Add "롻떾"
                If Mismatched뛱럷(Grades(i)) Then MismatchedList.Add "뛱럷"
                If Mismatched럺벛됵(Grades(i)) Then MismatchedList.Add "럺벛됵"
                If Mismatched긏깋긳(Grades(i)) Then MismatchedList.Add "긏깋긳"
                If Mismatched댬덒됵(Grades(i)) Then MismatchedList.Add "댬덒됵"
        End Select
        If MismatchedList.Count > 0 Then
            Dim MismatchedArray() As Variant
            Dim Message As String
            MismatchedArray = LIB.CollectionItemsToArray(MismatchedList)
            Message = Grades(i) & "궻 " & Join(MismatchedArray, "갂")
            Messages.Add Message
        End If
    Next
    If Messages.Count = 0 Then Exit Function
    MismatchedClassHourMessage = Join(LIB.CollectionItemsToArray(Messages), vbCrLf)
End Function
Private Function Count롻떾(ByVal Grade As String) As Long
    Dim RET As Long
    Dim Class As Variant
    For Each Class In TimeTables
        If Class Like "#뛝렄" & Grade Then
            If Me.TimeTables.Item(Class) = "걵" Then
                RET = RET + 1
            End If
        End If
    Next
    Count롻떾 = RET
End Function
Private Function Count뛱럷(ByVal Grade As String) As Long
    Dim RET As Long
    Dim Class As Variant
    For Each Class In TimeTables
        If Class Like "#뛝렄" & Grade Then
            If Me.TimeTables.Item(Class) = "뛱" Then
                RET = RET + 1
            End If
        End If
    Next
    Count뛱럷 = RET
End Function
Private Function Count럺벛됵(ByVal Grade As String) As Long
    Dim RET As Long
    Dim Class As Variant
    For Each Class In TimeTables
        If Class Like "#뛝렄" & Grade Then
            If Me.TimeTables.Item(Class) = "럺" Then
                RET = RET + 1
            End If
        End If
    Next
    Count럺벛됵 = RET
End Function
Private Function Count긏깋긳(ByVal Grade As String) As Long
    Dim RET As Long
    Dim Class As Variant
    For Each Class In TimeTables
        If Class Like "#뛝렄" & Grade Then
            If Me.TimeTables.Item(Class) = "긏" Then
                RET = RET + 1
            End If
        End If
    Next
    Count긏깋긳 = RET
End Function
Private Function Count댬덒됵(ByVal Grade As String) As Long
    Dim RET As Long
    Dim Class As Variant
    For Each Class In TimeTables
        If Class Like "#뛝렄" & Grade Then
            If Me.TimeTables.Item(Class) = "댬" Then
                RET = RET + 1
            End If
        End If
    Next
    Count댬덒됵 = RET
End Function
Private Function Mismatched롻떾(ByVal Grade As String) As Boolean
    If Sum롻떾(Grade) = Count롻떾(Grade) Then Exit Function
    Mismatched롻떾 = True
End Function
Private Function Mismatched뛱럷(ByVal Grade As String) As Boolean
    If Sum뛱럷(Grade) = Count뛱럷(Grade) Then Exit Function
    Mismatched뛱럷 = True
End Function
Private Function Mismatched럺벛됵(ByVal Grade As String) As Boolean
    If Sum럺벛됵(Grade) = Count럺벛됵(Grade) Then Exit Function
    Mismatched럺벛됵 = True
End Function
Private Function Mismatched긏깋긳(ByVal Grade As String) As Boolean
    If Sum긏깋긳 = Count긏깋긳(Grade) Then Exit Function
    Mismatched긏깋긳 = True
End Function
Private Function Mismatched댬덒됵(ByVal Grade As String) As Boolean
    If Sum댬덒됵 = Count댬덒됵(Grade) Then Exit Function
    Mismatched댬덒됵 = True
End Function


