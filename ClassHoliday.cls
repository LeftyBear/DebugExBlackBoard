'@Ignore UseMeaningfulName, ProcedureNotUsed
Public Function 秋分の日(ByVal 年 As Long) As Date
    '@Ignore UseMeaningfulName
    Dim 内部変数 As Double
    Select Case 年
        Case Year(祝日法施行) To 1979
            内部変数 = 23.2588
        Case 1980 To 2099
            内部変数 = 23.2488
        Case 2100 To 2150
            内部変数 = 24.2488
        Case Else
            Exit Function
    End Select
    '@Ignore UseMeaningfulName
    Dim 月 As Long
    '@Ignore UseMeaningfulName
    Dim 日 As Long
    月 = 9
    日 = Int(内部変数 + 0.242194 * (年 - 1980) - Int((年 - 1980) / 4))
    秋分の日 = 月日指定(年, 月, 日)
    If 秋分の日 < 祝日法施行 Then 秋分の日 = 0
End Function
