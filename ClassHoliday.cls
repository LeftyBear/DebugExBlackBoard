'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
Private Function 月日指定(ByVal 年 As Long, ByVal 月 As Long, ByVal 日 As Long) As Date
    If Not IsValidYears(年) Then Exit Function
    If Not IsValidMonths(月) Then Exit Function
    If Not IsValidDays(日) Then Exit Function
    月日指定 = DateSerial(年, 月, 日)
End Function
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
'@Ignore UseMeaningfulName
Private Function 月週曜日指定(ByVal 年 As Long, ByVal 月 As Long, ByVal 週 As Long, ByVal 曜日 As Long) As Date
    If Not IsValidWeeks(週) Then Exit Function
    If Not IsValidWeekday(曜日) Then Exit Function
    '@Ignore UseMeaningfulName
    Dim 初日 As Date
    '@Ignore UseMeaningfulName
    Dim 初日の曜日 As Long
    '@Ignore UseMeaningfulName
    Dim 初日から指定曜日までの日数 As Long
    初日 = 月日指定(年, 月, 1)
    初日の曜日 = Weekday(初日)
    初日から指定曜日までの日数 = IIf(曜日 >= 初日の曜日, 曜日 - 初日の曜日, 曜日 - 初日の曜日 + 7)
    '@Ignore UseMeaningfulName
    Dim 初日から指定週の曜日までの日数 As Long
    初日から指定週の曜日までの日数 = 初日から指定曜日までの日数 + 7 * (週 - 1)
    月週曜日指定 = DateAdd("d", 初日から指定週の曜日までの日数, 初日)
End Function
'@Ignore UseMeaningfulName
Public Function AddHolidays(ByVal 年 As Long) As Dictionary
    Dim RET As Dictionary
    Set RET = New Dictionary
    Dim HolidayNames() As Variant
    HolidayNames = 国民の祝日名
    Dim i As Long
    For i = LBound(HolidayNames) To UBound(HolidayNames)
        Dim ReturnedDate As Date
        ReturnedDate = CallByName(Me, HolidayNames(i), VbMethod, 年)
        If ReturnedDate > 0 Then RET.Add ReturnedDate, HolidayNames(i)
    Next
    Const SubstituteHolidayName As String = "振替休日"
    Dim SubstituteHoliday As Collection
    Set SubstituteHoliday = 振替休日(RET)
    If Not SubstituteHoliday Is Nothing Then
        Dim HolidayDate As Variant
        For Each HolidayDate In SubstituteHoliday
            RET.Add HolidayDate, SubstituteHolidayName
        Next
    End If
    Const NationalHolidayName As String = "国民の休日"
    Dim NationalHoliday As Collection
    Set NationalHoliday = 国民の休日(RET)
    If Not NationalHoliday Is Nothing Then
        For Each HolidayDate In NationalHoliday
            RET.Add HolidayDate, NationalHolidayName
        Next
    End If
    Set AddHolidays = LIB.SortDictionary(RET, xlAscending)
End Function
'@Ignore UseMeaningfulName
Private Function 振替休日(ByVal HolidayList As Dictionary) As Collection
    Dim RET As Collection
    Set RET = New Collection
    Dim HolidayDate As Variant
    For Each HolidayDate In HolidayList
        If Weekday(HolidayDate) = vbSunday Then
            If 祝日法改正_振替休日1 <= HolidayDate And HolidayDate < 祝日法改正_振替休日2 Then
                '祝日が日曜日の場合はその翌日の月曜日を休日とする
                RET.Add DateAdd("d", 1, HolidayDate)
            ElseIf 祝日法改正_振替休日2 <= HolidayDate Then
                '「国民の祝日」が日曜日に当たるとき、その日の後の最も近い平日を休日とする
                '@Ignore UseMeaningfulName
                Dim 休日 As Date
                休日 = DateAdd("d", 1, HolidayDate)
                Do
                    If Not HolidayList.Exists(休日) Then Exit Do
                    休日 = DateAdd("d", 1, 休日)
                Loop
                RET.Add 休日
            End If
        End If
    Next
    Set 振替休日 = RET
End Function
'@Ignore UseMeaningfulName
Private Function 国民の休日(ByVal HolidayList As Dictionary) As Collection
    Dim RET As Collection
    Set RET = New Collection
    Dim HolidayDate As Variant
    For Each HolidayDate In HolidayList
        If 祝日法改正_国民の休日 <= HolidayDate Then
            '前日と翌日の両方を「国民の祝日」に挟まれた平日は休日とする
            '@Ignore UseMeaningfulName
            Dim 休日 As Date
            休日 = DateAdd("d", 1, HolidayDate)
            Do
                If Not HolidayList.Exists(休日) Then Exit Do
                休日 = DateAdd("d", 1, 休日)
            Loop
            If Weekday(休日) <> vbSunday Then
                '@Ignore UseMeaningfulName
                Dim 休日の翌日 As Date
                休日の翌日 = DateAdd("d", 1, 休日)
                If HolidayList.Exists(休日の翌日) Then
                    RET.Add 休日
                End If
            End If
        End If
    Next
    Set 国民の休日 = RET
End Function
'@Ignore UseMeaningfulName
Private Function IsValidYears(ByVal 年 As Long) As Boolean
    If 年 < Year(祝日法施行) Or LimitYear < 年 Then
        MsgBox "年の指定に誤りがあります。", vbExclamation, "日付指定エラー"
        Exit Function
    End If
    IsValidYears = True
End Function
'@Ignore UseMeaningfulName
Private Function IsValidMonths(ByVal 月 As Long) As Boolean
    If 月 < 1 Or 12 < 月 Then
        MsgBox "月の指定に誤りがあります。", vbExclamation, "日付指定エラー"
        Exit Function
    End If
    IsValidMonths = True
End Function
'@Ignore UseMeaningfulName
Private Function IsValidDays(ByVal 日 As Long) As Boolean
    If 日 < 1 Or 31 < 日 Then
        MsgBox "日の指定に誤りがあります。", vbExclamation, "日付指定エラー"
        Exit Function
    End If
    IsValidDays = True
End Function
'@Ignore UseMeaningfulName
Private Function IsValidWeeks(ByVal 週 As Long) As Boolean
    If 週 < 1 Or 5 < 週 Then
        MsgBox "週の指定に誤りがあります。", vbExclamation, "日付指定エラー"
        Exit Function
    End If
    IsValidWeeks = True
End Function
'@Ignore UseMeaningfulName
Private Function IsValidWeekday(ByVal 曜日 As Long) As Boolean
    If 曜日 < 1 Or 7 < 曜日 Then
        MsgBox "曜日の指定に誤りがあります。", vbExclamation, "日付指定エラー"
        Exit Function
    End If
    IsValidWeekday = True
End Function


