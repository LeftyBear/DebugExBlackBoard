        "憲法記念日", "こどもの日", "海の日", "スポーツの日", "山の日", _
        "敬老の日", "秋分の日", "体育の日", "文化の日", "勤労感謝の日", _
        "春分の日", "天皇誕生日", "即位礼正殿の儀", "天皇の即位", "皇太子明仁親王の結婚の儀", _
        "皇太子徳仁親王の結婚の儀", "昭和天皇の大喪の礼")
End Function
'@Ignore UseMeaningfulName, ProcedureNotUsed
Public Function 元日(ByVal 年 As Long) As Date
    Dim RET As Date
    '@Ignore UseMeaningfulName
    Const 月 As Long = 1
    '@Ignore UseMeaningfulName
    Const 日 As Long = 1
    Select Case 年
        Case Year(祝日法施行) To LimitYear
            RET = 月日指定(年, 月, 日)
            If RET < 祝日法施行 Then Exit Function
        Case Else
            Exit Function
    End Select
    元日 = RET
End Function
