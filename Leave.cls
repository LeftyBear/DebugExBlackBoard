VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "Leave"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
'@Folder("Form")
Option Explicit
Implements ILeave
Private ListViewControl As IListViewControl
Private ListBoxDayDutyOrder As MSForms.ListBox
Private OptionButton特休 As MSForms.OptionButton
Private OptionButton育休 As MSForms.OptionButton
Private OptionButton病休 As MSForms.OptionButton
Private DataBody() As Variant
Private TargetName As String
Private DisplayName As String
Private LeaveTypeName As String
Private FirstDate As Date
Private LastDate As Date
Private Sub Class_Initialize()
    With FormExBB
        Set ListViewControl = New ListViewControl
        Set ListViewControl.TargetListView = .Controls("ListView長期休暇")
        Set ListBoxDayDutyOrder = .Controls("ListBox日直順")
        Set OptionButton特休 = .Controls("OptionButton特休")
        Set OptionButton育休 = .Controls("OptionButton育休")
        Set OptionButton病休 = .Controls("OptionButton病休")
    End With
    With ListViewControl
        TargetName = CStr(.GetItem("取得者"))
        LeaveTypeName = CStr(.GetItem("種別"))
        FirstDate = CDate(.GetItem("開始日"))
        LastDate = CDate(.GetItem("終了日"))
        DisplayName = CStr(.GetItem("表示名"))
        DataBody = .GetItems
    End With
End Sub
Private Sub ILeave_Register(ByVal BasisDate As Date, ByVal MsgTitle As String)
    TargetName = LIB.SelectedItemJustOne(ListBoxDayDutyOrder)
    FirstDate = LIB.ReturnDateByInputBox("開始日を入力してください。", MsgTitle, BasisDate)
    If FirstDate = 0 Then Exit Sub
    LastDate = LIB.ReturnDateByInputBox("終了日を入力してください。", MsgTitle, BasisDate)
    If LastDate = 0 Then Exit Sub
    If LIB.InvalidDateFirstToLast(BasisDate, FirstDate, LastDate, MsgTitle) Then Exit Sub
    DisplayName = InputBox("日誌等に印字する表示名を入力してください。", MsgTitle, TargetName)
    If DisplayName Like vbNullString Then Exit Sub
    LeaveTypeName = GetLeaveTypeName
    Dim RecordList As Dictionary
    Set RecordList = New Dictionary
    With RecordList
        .Add "取得者", TargetName
        .Add "種別", LeaveTypeName
        .Add "開始日", FirstDate
        .Add "終了日", LastDate
        .Add "表示名", DisplayName
    End With
    With ListViewControl
        .AddItem RecordList
        DataBody = .GetItems
    End With
End Sub
Private Sub ILeave_Remove()
    ListViewControl.RemoveItem
End Sub
Private Function ILeave_DataBody() As Variant()
    ILeave_DataBody = DataBody
End Function
Private Function ILeave_TargetName() As String
    ILeave_TargetName = TargetName
End Function
Private Function ILeave_DisplayName() As String
    ILeave_DisplayName = DisplayName
End Function
Private Function ILeave_LeaveTypeName() As String
    ILeave_LeaveTypeName = LeaveTypeName
End Function
Private Function ILeave_FirstDate() As Date
    ILeave_FirstDate = FirstDate
End Function
Private Function ILeave_LastDate() As Date
    ILeave_LastDate = LastDate
End Function
Private Function GetLeaveTypeName() As String
    Dim RET As String
    If CBool(OptionButton特休.Value) Then
        RET = OptionButton特休.Caption
    ElseIf CBool(OptionButton育休.Value) Then
        RET = OptionButton育休.Caption
    ElseIf CBool(OptionButton病休.Value) Then
        RET = OptionButton病休.Caption
    End If
    GetLeaveTypeName = RET
End Function
